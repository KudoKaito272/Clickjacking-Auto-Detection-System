{
  "manifest_version": 3,
  "name": "CADS",
  "version": "1.121",
  "description": "Clickjacking Auto Detection System",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "notifications",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/CADS-16.png",
    "48": "images/CADS-48.png",
    "128": "images/CADS-128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/CADS-16.png",
      "48": "images/CADS-48.png",
      "128": "images/CADS-128.png"
    },
    "default_popup": "ui/home.html",
    "default_title": "CADS"

  },
  "host_permissions": [
    "<all_urls>"
  ]
}
